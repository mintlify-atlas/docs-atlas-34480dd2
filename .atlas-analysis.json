  "keyFeatures": [
    "Secure Secret Storage with encryption at rest",
    "Dynamic Secrets generation for AWS, databases, and more",
    "Data Encryption as a service via Transit secrets engine",
    "Lease-based secret lifecycle with automatic revocation",
    "Multiple auth methods: AppRole, AWS, GitHub, LDAP, TLS certs",
    "Fine-grained ACL policies for access control",
    "Audit logging for all secret access",
    "Namespaces for multi-tenancy",
    "High availability with Raft integrated storage",
    "Plugin system for extensible secrets engines and auth methods"
  ],
  "publicApiSurface": [
    "vault server",
    "vault status",
    "vault login",
    "vault kv get/put/delete/list",
    "vault secrets enable/disable/list",
    "vault auth enable/disable/list",
    "vault policy write/read/list/delete",
    "vault token create/lookup/renew/revoke",
    "vault operator init/unseal/seal/rekey",
    "vault lease renew/revoke",
    "vault plugin register/deregister/list",
    "vault namespace create/delete/list",
    "GET/POST /v1/sys/init",
    "PUT /v1/sys/unseal",
    "GET /v1/sys/seal-status",
    "GET /v1/sys/health",
    "POST /v1/auth/<method>/login",
    "GET /v1/<secrets-engine>/<path>",
    "POST /v1/<secrets-engine>/<path>",
    "DELETE /v1/<secrets-engine>/<path>",
    "GET /v1/sys/mounts",
    "POST /v1/sys/mounts/<path>",
    "GET /v1/sys/policies/acl",
    "POST /v1/sys/policies/acl/<name>",
    "api.NewClient(config)",
    "client.Logical().Read(path)",
    "client.Logical().Write(path, data)",
    "client.Auth().Token().LookupSelf()",
    "client.KVv2(mount).Get(ctx, path)",
    "client.KVv2(mount).Put(ctx, path, data)"
  ]
